# QGraph AI Service environment example
# Copy this file to .env.prod for production Compose and fill in real values there.

# Compose host exposure
# Production Compose pins the host bind address to 127.0.0.1 so the FastAPI
# service is reachable only from the VPS itself. Do not publish this service
# through ai.qgraph.org; public traffic should reach Django, which then calls
# this private URL.
QGRAPH_AI_HOST_PORT=8001

# Django-side production example (not read by this service):
# AI_BACKEND_URL=http://127.0.0.1:8001
# SEARCH_AI_BACKEND_URL=http://127.0.0.1:8001

# Runtime
QGRAPH_AI_ENVIRONMENT=production
QGRAPH_AI_LOG_LEVEL=info

# Service identity
QGRAPH_AI_SERVICE_NAME=qgraph-ai-service
QGRAPH_AI_SERVICE_VERSION=0.1.0

# Response/schema metadata
QGRAPH_AI_RENDER_SCHEMA_VERSION=v1
QGRAPH_AI_SEARCH_BACKEND_NAME=qgraph-ai-search
QGRAPH_AI_SEARCH_BACKEND_VERSION=2026-04-01
QGRAPH_AI_SEGMENTATION_MODEL_NAME=segmentation-pipeline
QGRAPH_AI_SEGMENTATION_MODEL_VERSION=2026-04-01

# Future provider settings
# The current bootstrap service does not read provider API keys or model names.
# Add them here only when src/config.py and the service code support them.
# QGRAPH_AI_LLM_API_KEY=
# QGRAPH_AI_LLM_MODEL=
