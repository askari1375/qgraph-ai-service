# QGraph AI Service — environment template
#
# This is the LOCAL/DEV template and the canonical list of variables the AI
# service reads. Every variable below is prefixed QGRAPH_AI_ and consumed by
# src/config.py. Copy to `.env` to run the app locally (uvicorn or the dev
# docker-compose).
#
# PRODUCTION values are NOT configured here. On the VPS the AI service's runtime
# env lives in qgraph-deploy/compose/production/env/ai-service.env (gitignored),
# and stack/orchestration values (the host port mapping, the shared Docker
# network, host mount paths) live in qgraph-deploy's stack .env — never in this
# file. Keep this file limited to variables the service actually reads.

# --- Runtime ---
QGRAPH_AI_ENVIRONMENT=development
QGRAPH_AI_LOG_LEVEL=info

# --- Service identity ---
QGRAPH_AI_SERVICE_NAME=qgraph-ai-service
QGRAPH_AI_SERVICE_VERSION=0.1.0

# --- Response/schema metadata ---
QGRAPH_AI_RENDER_SCHEMA_VERSION=v1
QGRAPH_AI_SEARCH_BACKEND_NAME=qgraph-ai-search
QGRAPH_AI_SEARCH_BACKEND_VERSION=2026-04-01

# --- Search retrieval ---
# OpenSearch is the only retrieval backend (there is no mock mode). The serving
# alias is the single source of truth for "which index is live": the indexing CLI
# builds an immutable physical index, validates it against the golden set, and
# atomically repoints the alias — there is no snapshot id/hash to copy. The active
# snapshot id/hash are read from the index profile for provenance, not configured.
QGRAPH_AI_SEARCH_CORPUS_SNAPSHOT_CACHE_DIR=/app/data/corpus_snapshots
# Heuristic scale for mapping an absolute BM25 score to a 0..1 confidence via
# 1 - exp(-score / k). Larger k => more conservative confidence.
QGRAPH_AI_SEARCH_CONFIDENCE_SCALE_K=10.0

# --- Django internal corpus snapshot export ---
QGRAPH_AI_DJANGO_INTERNAL_BASE_URL=http://web:8000
QGRAPH_AI_DJANGO_INTERNAL_TOKEN=
QGRAPH_AI_DJANGO_INTERNAL_TIMEOUT_SECONDS=10

# --- OpenSearch lexical retrieval (security-enabled: https + basic auth, dev and prod) ---
# The dev compose runs OpenSearch with the security plugin on; the password must
# match OPENSEARCH_INITIAL_ADMIN_PASSWORD (dev default below; set a strong value in
# production). The self-signed dev cert is not verified for this internal hop; to
# verify, point CA_CERT_PATH at the cluster's CA bundle and set VERIFY_CERTS=true.
QGRAPH_AI_OPENSEARCH_URL=https://opensearch:9200
# The serving alias the app queries; activation repoints it at a new physical
# index version (default: qgraph-ayah-lexical-active). Physical indices are named
# <prefix>-<YYYYMMDD>-<NNN> by the indexing CLI.
QGRAPH_AI_OPENSEARCH_ALIAS=qgraph-ayah-lexical-active
QGRAPH_AI_OPENSEARCH_TIMEOUT_SECONDS=10
QGRAPH_AI_OPENSEARCH_USERNAME=admin
QGRAPH_AI_OPENSEARCH_PASSWORD=DevAdmin123!
QGRAPH_AI_OPENSEARCH_VERIFY_CERTS=false
QGRAPH_AI_OPENSEARCH_CA_CERT_PATH=

# --- Segmentation ---
QGRAPH_AI_SEGMENTATION_MODEL_NAME=segmentation-pipeline
QGRAPH_AI_SEGMENTATION_MODEL_VERSION=2026-04-01
QGRAPH_AI_SEGMENTATION_ARTIFACTS_DIR=/app/data/segmentation_artifacts

# --- Optional dev docker-compose overrides (not read by the app) ---
# The dev docker-compose.yml interpolates these with safe defaults; set them only
# to override locally. They are compose-level, not application config.
# OPENSEARCH_INITIAL_ADMIN_PASSWORD=DevAdmin123!
# QGRAPH_OPENSEARCH_IMAGE=opensearchproject/opensearch:2.17.1

# --- Future provider settings ---
# The current service does not read LLM provider keys or model names. Add them
# here only when src/config.py and the service code support them.
# QGRAPH_AI_LLM_API_KEY=
# QGRAPH_AI_LLM_MODEL=
