# QGraph AI Service environment example
# Copy this file to .env.prod for production Compose and fill in real values there.

# Production private Docker network
#
# The backend and AI service production compose stacks attach to this external
# Docker network. Keep this optional variable aligned with qgraph-backend.
QGRAPH_PRIVATE_DOCKER_NETWORK=qgraph-private

# Compose host exposure
# Production Compose pins the host bind address to 127.0.0.1 so the FastAPI
# service is reachable only from the VPS itself for smoke checks. Do not publish
# this service through ai.qgraph.org; public traffic should reach Django, which
# then calls the private Docker DNS URL.
QGRAPH_AI_HOST_PORT=8001

# Production prepared segmentation artifacts
#
# Store reviewed artifact files on the host so they survive image rebuilds and
# container replacement. Production Compose mounts this directory read-only at
# /app/data/segmentation_artifacts.
QGRAPH_AI_SEGMENTATION_ARTIFACTS_HOST_DIR=/opt/qgraph/data/ai-service/segmentation_artifacts

# Django-side production example (not read by this service):
# AI_BACKEND_URL=http://ai-backend:8001

# Runtime
QGRAPH_AI_ENVIRONMENT=production
QGRAPH_AI_LOG_LEVEL=info

# Service identity
QGRAPH_AI_SERVICE_NAME=qgraph-ai-service
QGRAPH_AI_SERVICE_VERSION=0.1.0

# Response/schema metadata
QGRAPH_AI_RENDER_SCHEMA_VERSION=v1
QGRAPH_AI_SEARCH_BACKEND_NAME=qgraph-ai-search
QGRAPH_AI_SEARCH_BACKEND_VERSION=2026-04-01

# Search retrieval
#
# Keep mock mode until a corpus snapshot has been pulled, normalized, indexed in
# OpenSearch, and the active snapshot id/hash below match the index profile.
# In `opensearch` mode the active snapshot id AND hash are REQUIRED — the service
# refuses to serve retrieval requests without them so the index-profile drift
# check can never be silently skipped.
QGRAPH_AI_SEARCH_LEXICAL_BACKEND_MODE=mock
QGRAPH_AI_SEARCH_CORPUS_SNAPSHOT_CACHE_DIR=/app/data/corpus_snapshots
QGRAPH_AI_SEARCH_ACTIVE_CORPUS_SNAPSHOT_ID=
QGRAPH_AI_SEARCH_ACTIVE_CORPUS_SNAPSHOT_HASH=
QGRAPH_AI_SEARCH_RANKER_PROFILE_ID=lexical_bm25_v1
# Heuristic scale for mapping an absolute BM25 score to a 0..1 confidence via
# 1 - exp(-score / k). Larger k => more conservative confidence.
QGRAPH_AI_SEARCH_CONFIDENCE_SCALE_K=10.0

# Django internal corpus snapshot export
QGRAPH_AI_DJANGO_INTERNAL_BASE_URL=http://web:8000
QGRAPH_AI_DJANGO_INTERNAL_TOKEN=
QGRAPH_AI_DJANGO_INTERNAL_TIMEOUT_SECONDS=10

# OpenSearch lexical retrieval
QGRAPH_AI_OPENSEARCH_URL=http://opensearch:9200
QGRAPH_AI_OPENSEARCH_INDEX_NAME=qgraph-ayah-lexical-v1
QGRAPH_AI_OPENSEARCH_TIMEOUT_SECONDS=10

QGRAPH_AI_SEGMENTATION_MODEL_NAME=segmentation-pipeline
QGRAPH_AI_SEGMENTATION_MODEL_VERSION=2026-04-01
QGRAPH_AI_SEGMENTATION_ARTIFACTS_DIR=/app/data/segmentation_artifacts

# Future provider settings
# The current service does not read LLM provider keys or model names.
# Add them here only when src/config.py and the service code support them.
# QGRAPH_AI_LLM_API_KEY=
# QGRAPH_AI_LLM_MODEL=
